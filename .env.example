# Supabase (région EU). Ces clés PUBLIC_* sont inlinées au BUILD par $env/static/public.
# L'anon key est PUBLIQUE par design : la sécurité repose sur la RLS Postgres, pas sur le secret.
# En CI : déclarer dans Settings > Secrets and variables > Actions.
PUBLIC_SUPABASE_URL="https://VOTRE-PROJET.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="VOTRE_ANON_KEY"
